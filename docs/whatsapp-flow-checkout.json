    ],
    "MINIMUM_NOT_REACHED": [
      "CATEGORIES",
      "CANCELLED"
    ],
    "CUSTOMER_DATA": [
      "ADDRESS_DATA"
    ],
    "ADDRESS_DATA": [
      "SHIPPING_OPTIONS"
    ],
    "SHIPPING_OPTIONS": [
      "CONFIRM_ORDER",
      "HUMAN_ATTENDANT"
    ],
    "CONFIRM_ORDER": [
      "ORDER_CREATED",
      "CART_REVIEW",
      "CANCELLED"
    ],
    "ORDER_CREATED": [],
    "OUT_OF_STOCK": [],
    "HUMAN_ATTENDANT": [],
    "CANCELLED": []
