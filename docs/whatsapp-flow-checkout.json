{
  "version": "7.3",
  "data_api_version": "3.0",
  "routing_model": {
    "MAIN_MENU": [
      "CATEGORIES",
      "PRODUCT_LIST",
      "CART_REVIEW",
      "HUMAN_ATTENDANT"
    ],
    "CATEGORIES": [
      "PRODUCT_LIST"
    ],
    "PRODUCT_LIST": [
      "CHOOSE_VARIANT",
      "OUT_OF_STOCK"
    ],
    "CHOOSE_VARIANT": [
      "CHOOSE_QUANTITY",
      "OUT_OF_STOCK"
    ],
    "CHOOSE_QUANTITY": [
      "ITEM_ADDED",
      "OUT_OF_STOCK"
    ],
    "ITEM_ADDED": [
      "CATEGORIES",
      "CART_REVIEW",
      "CUSTOMER_DATA",
      "MINIMUM_NOT_REACHED",
      "CANCELLED"
    ],
