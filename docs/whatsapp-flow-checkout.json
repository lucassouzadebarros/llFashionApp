  "screens": [
    {
      "id": "MAIN_MENU",
      "title": "Boas-vindas",
      "data": {
        "flow_token": {
          "type": "string",
          "__example__": "token-teste"
        },
        "minimum_order_total": {
          "type": "string",
          "__example__": "R$ 200,00"
        },
        "intro_text": {
          "type": "string",
          "__example__": "Trabalhamos com moda feminina no atacado. Pedido minimo: R$ 200,00."
        },
        "main_actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          },
          "__example__": [
            {
              "id": "BUY_CATEGORY",
              "title": "Comprar por categoria",
              "description": "Montar carrinho no atacado"
            },
            {
              "id": "VIEW_NEW",
              "title": "Ver novidades",
              "description": "Pecas disponiveis em estoque"
            },
            {
              "id": "VIEW_PROMOS",
              "title": "Ver promocoes",
              "description": "Ofertas e oportunidades"
            },
            {
              "id": "VIEW_CART",
              "title": "Ver carrinho",
              "description": "Revisar itens"
            },
            {
              "id": "HUMAN",
              "title": "Falar com atendente",
              "description": "Chamar atendimento"
            }
          ]
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "type": "TextHeading",
            "text": "Bem-vinda a LLFashion Moda"
          },
          {
            "type": "TextBody",
            "text": "${data.intro_text}"
          },
          {
            "type": "TextBody",
            "text": "Escolha como quer continuar. Voce pode montar o carrinho por categoria, ver novidades, promocoes ou revisar o carrinho."
          },
          {
            "type": "Form",
            "name": "form",
            "children": [
              {
                "type": "RadioButtonsGroup",
                "label": "O que voce deseja fazer?",
                "name": "main_action",
                "data-source": "${data.main_actions}",
                "required": true
              },
              {
                "type": "Footer",
                "label": "Continuar",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "flow_token": "${data.flow_token}",
                    "main_action": "${form.main_action}"
                  }
                }
              }
            ]
          },
          {
            "type": "TextCaption",
            "text": "Gerenciada por LL Fashion"
          }
        ]
      }
    },
    {
      "id": "CATEGORIES",
