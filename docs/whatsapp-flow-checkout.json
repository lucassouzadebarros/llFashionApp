            "name": "form",
            "children": [
              {
                "type": "RadioButtonsGroup",
                "label": "Categoria",
                "name": "category_id",
                "data-source": "${data.categories}",
                "required": true
              },
              {
                "type": "Footer",
                "label": "Ver produtos",
                "on-click-action": {
                  "name": "data_exchange",
                  "payload": {
                    "flow_token": "${data.flow_token}",
                    "category_id": "${form.category_id}"
                  }
                }
              }
            ]
          }
        ]
      }
